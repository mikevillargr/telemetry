# ===========================================
# Growth Rocket BI Platform — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# Anthropic
ANTHROPIC_API_KEY=


# Database
DATABASE_URL=postgresql://grbi_user:grbi_pass@localhost:5432/grbi
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@growthrocket.com
ADMIN_PASSWORD=admin123

# Encryption (for connector credentials — generate a 32-byte hex key)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Connectors (add when available)
SEMRUSH_API_KEY=
BRAVE_API_KEY=

# App
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001
NODE_ENV=development
